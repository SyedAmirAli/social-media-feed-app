# =============================================================================
# Environment variables — copy this file to `.env` and fill in real values:
#
#   cp .env.example .env
#
# Never commit `.env`. Only this example file should be shared.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (required)
# -----------------------------------------------------------------------------
# Prisma + the Next.js app read this connection string.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
#
# Options:
#   - Local:     postgres://postgres:postgres@localhost:5432/social_feed?schema=public
#   - Prisma Postgres / Neon / Supabase / Railway / etc.: paste the URI from their dashboard
#
# Used by:
#   - prisma.config.ts (migrations & seed)
#   - src/lib/prisma.ts (runtime Prisma Client via @prisma/adapter-pg)
#   - prisma/seed.ts
DATABASE_URL="postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Optional. API key from Prisma Data Platform / Prisma Postgres console.
# Only needed if your team uses Prisma-managed features that require it.
# Leave blank for a normal self-hosted or third-party Postgres instance.
PRISMA_API_KEY=

# -----------------------------------------------------------------------------
# Cloudflare R2 — S3-compatible object storage (required for uploads)
# -----------------------------------------------------------------------------
# Create these in the Cloudflare dashboard:
#   1. R2 → Create bucket (name → R2_BUCKET)
#   2. R2 → Manage R2 API Tokens → Create API token
#        - Permissions: Object Read & Write (account or bucket-scoped)
#        - Copy Access Key ID + Secret Access Key
#   3. Account → R2 → Settings / Overview → S3 API endpoint
#        Looks like: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#
# Optional Cloudflare API token string (Account API Tokens). Used for dashboard /
# token automation — not required for the S3 SDK path used by Bucket.
R2_TOKEN_VALUE=

# S3 Access Key ID from the R2 API token you created.
R2_ACCESS_KEY_ID=

# S3 Secret Access Key from the same R2 API token. Keep this private.
R2_SECRET_ACCESS_KEY=

# S3-compatible API endpoint for your Cloudflare account (no bucket name in path).
# Example: https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"

# Exact R2 bucket name (must already exist).
R2_BUCKET="your-bucket-name"

# Virtual folder prefix inside the bucket for this project’s files.
# Uploads resolve like: <prefix>/posts/<file>.png
# Persist the FULL key (including prefix) in the database.
R2_BUCKET_PREFIX="appifylab"

# -----------------------------------------------------------------------------
# Public asset URL base (required for avatars / post images in the UI)
# -----------------------------------------------------------------------------
# Public origin used by `asset()` in src/config/utils.ts to build browser URLs.
#
# Point this at a public hostname that serves your R2 objects, for example:
#   - R2 custom domain: https://cdn.example.com
#   - r2.dev public bucket URL: https://pub-xxxxx.r2.dev
#
# Objects are requested as: ${ASSETS_BASE_URL}/${R2_BUCKET_PREFIX}/...
# Ensure public read (custom domain or public bucket access) matches this URL.
ASSETS_BASE_URL="https://your-public-r2-or-cdn-domain.com"

# -----------------------------------------------------------------------------
# Auth / JWT (required)
# -----------------------------------------------------------------------------
# Secret used by jose to sign and verify session JWTs (src/lib/jwt.ts).
# Generate a strong random value, e.g.:
#   openssl rand -base64 32
JWT_SECRET=

# Token lifetime passed to jose. Examples: 1h, 7d, 30d
JWT_EXPIRATION="30d"
